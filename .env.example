# Groq — транскрибация Speech-to-Text (/api/transcribe) и при необходимости анализ (/api/analyze)
GROQ_API_KEY=
# Модель STT по умолчанию: whisper-large-v3 (быстро, русский, mp3/wav/m4a)
GROQ_TRANSCRIPTION_MODEL=

# Модель чата для анализа (если используете Groq для LLM; по умолчанию llama-3.3-70b-versatile)
GROQ_MODEL=

# Либо OpenRouter для анализа, если GROQ_API_KEY не задан (только LLM, не STT)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_MODEL=
